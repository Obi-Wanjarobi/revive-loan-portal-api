# Railway sets DATABASE_URL automatically once you attach a Postgres plugin — don't set it by hand.

# Generate a long random string for this (e.g. run: openssl rand -hex 32)
JWT_SECRET=

# A separate long random string — this is the "staff door" key Pulse CRM uses to push updates.
# Same idea as the LendingPad/SignNow keys already stored in Pulse's Admin > API Keys tab.
INTERNAL_API_KEY=

# Comma-separated list of domains allowed to call this API from a browser.
# Example: https://www.myrevivecapital.com,https://portal.myrevivecapital.com
CORS_ORIGINS=*
